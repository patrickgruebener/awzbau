# Ignore everything by default
/*
/*/

# Allow specific project files
!.gitignore
!README.md
!SETUP.md
!docker-compose.yml
!/wp-content/

# Allow .claude/memory.md (project memory log)
!/.claude/
/.claude/*
!/.claude/memory.md

# Ignore everything in wp-content
/wp-content/*
/wp-content/*/

# Allow custom theme
!/wp-content/themes/
/wp-content/themes/*
!/wp-content/themes/vantage-childtheme/

# Allow custom plugins folder (but empty for now)
!/wp-content/plugins/
/wp-content/plugins/*
!/wp-content/mu-plugins/
/wp-content/mu-plugins/*
!/wp-content/mu-plugins/awz-stec-performance.php
!/wp-content/mu-plugins/awz-stec-i18n-loader-hotfix.php
!/wp-content/mu-plugins/awz-cf7-antispam.php
!/wp-content/mu-plugins/awz-admin-menu.php

# Ignore uploads and cache
wp-content/uploads/
wp-content/cache/
wp-content/upgrade/
wp-content/backup*/

# Ignore logs and system files
*.log
*.tmp
.DS_Store
Thumbs.db

# Ignore sensitive config
wp-config.php
.htaccess

# Allow structure folders
!/docs/
!/tasks/
!/tests/
/tests/*
!/tests/manual/
/tests/manual/*
!/tests/manual/performance-calendar.md
!/tests/manual/post-deployment.md
!/database/
/database/*
!/database/.gitkeep
